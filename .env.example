# ── PostgreSQL (AWS RDS in production) ───────────────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_NAME=careerdb
DB_USERNAME=careeruser
DB_PASSWORD=careerpass

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGO_URI=mongodb://careeruser:careerpass@localhost:27017/careerdb?authSource=admin
MONGO_DATABASE=careerdb

# ── Redis (AWS ElastiCache in production) ────────────────────────────────────
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=careerpass

# ── RabbitMQ (Amazon MQ in production) ───────────────────────────────────────
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USERNAME=careeruser
RABBITMQ_PASSWORD=careerpass
RABBITMQ_QUEUE_JOB_CREATED=job.created

# ── AWS Cognito ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# JWKS endpoint: https://cognito-idp.{region}.amazonaws.com/{userPoolId}/.well-known/jwks.json

# ── AWS SES (email notifications) ────────────────────────────────────────────
AWS_SES_FROM_EMAIL=alerts@career.net
AWS_ACCESS_KEY_ID=AKIAIOSFODNN7EXAMPLE
AWS_SECRET_ACCESS_KEY=wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY

# ── Google Gemini AI Agent ────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Get a free key at: https://aistudio.google.com/app/apikey

# ── Service URLs (used by API Gateway and inter-service calls) ────────────────
JOB_SERVICE_URL=http://localhost:8081
SEARCH_SERVICE_URL=http://localhost:8082
NOTIFICATION_SERVICE_URL=http://localhost:8083
ADMIN_SERVICE_URL=http://localhost:8084
AI_AGENT_SERVICE_URL=http://localhost:8085

# ── API Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
