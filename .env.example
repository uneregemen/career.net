# ── PostgreSQL (Supabase) ─────────────────────────────────────────────────────
# Supabase project settings → Database → Connection string (URI)
DB_HOST=db.xxxxxxxxxxxx.supabase.co
DB_PORT=5432
DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=your-supabase-db-password

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
# Atlas dashboard → Connect → Drivers → copy connection string
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/?appName=<appname>
MONGO_DATABASE=careerdb

# ── Redis (Upstash) ───────────────────────────────────────────────────────────
# Upstash dashboard → Connect → Redis Client → copy connection string
# rediss:// (çift s) = SSL — Upstash için zorunlu
REDIS_URL=rediss://default:<password>@<host>.upstash.io:6379

# ── RabbitMQ (CloudAMQP) ──────────────────────────────────────────────────────
# CloudAMQP dashboard → instance → AMQP URL
# amqps:// prefix = SSL (zorunlu CloudAMQP için)
RABBITMQ_URL=amqps://<user>:<password>@<host>/<vhost>
RABBITMQ_QUEUE_JOB_CREATED=job.created

# ── AWS Cognito ───────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# JWKS endpoint: https://cognito-idp.{region}.amazonaws.com/{userPoolId}/.well-known/jwks.json

# ── Google Gemini AI Agent ────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
# Get a free key at: https://aistudio.google.com/app/apikey

# ── Service URLs (used by API Gateway and inter-service calls) ────────────────
JOB_SERVICE_URL=http://localhost:8081
SEARCH_SERVICE_URL=http://localhost:8082
NOTIFICATION_SERVICE_URL=http://localhost:8083
ADMIN_SERVICE_URL=http://localhost:8084
AI_AGENT_SERVICE_URL=http://localhost:8085

# ── API Gateway ───────────────────────────────────────────────────────────────
GATEWAY_PORT=8080

# ── Frontend (Next.js) ────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:8080
NEXT_PUBLIC_AWS_REGION=us-east-1
NEXT_PUBLIC_COGNITO_USER_POOL_ID=us-east-1_XXXXXXXXX
NEXT_PUBLIC_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
