{
  "family": "career-net-search-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::615471834704:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "search-service",
      "image": "615471834704.dkr.ecr.eu-north-1.amazonaws.com/career-net-search-service:latest",
      "portMappings": [
        {
          "containerPort": 8082,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "MONGO_DATABASE",
          "value": "careerdb"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "JOB_SERVICE_URL",
          "value": "http://job-service.career-net.local:8081"
        }
      ],
      "secrets": [
        {
          "name": "MONGO_URI",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/MONGO_URI-fxnpFf"
        },
        {
          "name": "COGNITO_USER_POOL_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/COGNITO_USER_POOL_ID-bGgkfr"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/career-net/search-service",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}