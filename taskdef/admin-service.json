{
  "family": "career-net-admin-service",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::615471834704:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "admin-service",
      "image": "615471834704.dkr.ecr.eu-north-1.amazonaws.com/career-net-admin-service:latest",
      "portMappings": [
        {
          "containerPort": 8084,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "DB_PORT",
          "value": "5432"
        },
        {
          "name": "DB_NAME",
          "value": "postgres"
        },
        {
          "name": "DB_USERNAME",
          "value": "postgres.mqjvwjqtbwknugtfogal"
        },
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "JOB_SERVICE_URL",
          "value": "http://job-service.career-net.local:8081"
        }
      ],
      "secrets": [
        {
          "name": "DB_HOST",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/DB_HOST-RhV4cp"
        },
        {
          "name": "DB_PASSWORD",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/DB_PASSWORD-LVMUeW"
        },
        {
          "name": "COGNITO_USER_POOL_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/COGNITO_USER_POOL_ID-bGgkfr"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/career-net/admin-service",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}