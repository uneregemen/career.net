{
  "family": "career-net-api-gateway",
  "networkMode": "awsvpc",
  "requiresCompatibilities": [
    "FARGATE"
  ],
  "cpu": "512",
  "memory": "1024",
  "executionRoleArn": "arn:aws:iam::615471834704:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "api-gateway",
      "image": "615471834704.dkr.ecr.eu-north-1.amazonaws.com/career-net-api-gateway:latest",
      "portMappings": [
        {
          "containerPort": 8080,
          "protocol": "tcp"
        }
      ],
      "environment": [
        {
          "name": "AWS_REGION",
          "value": "eu-north-1"
        },
        {
          "name": "JOB_SERVICE_URL",
          "value": "http://job-service.career-net.local:8081"
        },
        {
          "name": "SEARCH_SERVICE_URL",
          "value": "http://search-service.career-net.local:8082"
        },
        {
          "name": "NOTIFICATION_SERVICE_URL",
          "value": "http://notification-service.career-net.local:8083"
        },
        {
          "name": "ADMIN_SERVICE_URL",
          "value": "http://admin-service.career-net.local:8084"
        },
        {
          "name": "AI_AGENT_SERVICE_URL",
          "value": "http://ai-agent-service.career-net.local:8085"
        }
      ],
      "secrets": [
        {
          "name": "COGNITO_USER_POOL_ID",
          "valueFrom": "arn:aws:secretsmanager:eu-north-1:615471834704:secret:career-net/COGNITO_USER_POOL_ID-bGgkfr"
        }
      ],
      "logConfiguration": {
        "logDriver": "awslogs",
        "options": {
          "awslogs-group": "/ecs/career-net/api-gateway",
          "awslogs-region": "eu-north-1",
          "awslogs-stream-prefix": "ecs"
        }
      },
      "essential": true
    }
  ]
}